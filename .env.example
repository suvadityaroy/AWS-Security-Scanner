# AWS Configuration
# Copy this file to .env and fill in your values

# AWS Regions to scan (comma-separated)
# Example: AWS_REGIONS=us-east-1,us-west-2,eu-central-1
AWS_REGIONS=eu-north-1

# Optional: Specific Resource IDs for targeted scanning
# AWS_VPC_ID=vpc-xxxxx
# AWS_PUBLIC_SUBNET_ID=subnet-xxxxx
# AWS_PRIVATE_SUBNET_ID=subnet-xxxxx
# AWS_ROUTE_TABLE_ID=rtb-xxxxx
# AWS_IGW_ID=igw-xxxxx
# AWS_PERMISSIVE_ACL_ID=acl-xxxxx
